# ── 应用基础 ────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=True
APP_VERSION=0.1.0

# ── MySQL 数据库配置 ───────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=lcc
DB_CHARSET=utf8mb4

# 连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis 配置 ──────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery 队列与结果使用独立 DB
CELERY_BROKER_DB=1
CELERY_RESULT_DB=2

# ── JWT 配置 ────────────────────────────────────────────────────────────────────
# 生产环境必须替换为随机强密钥：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS 配置（逗号分隔）──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ── 文件存储 ─────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./storage/uploads
REPORT_DIR=./storage/reports
MAX_UPLOAD_SIZE_MB=50
